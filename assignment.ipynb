   "id": "cell-problem3",
   "metadata": {},
   "source": [
    "import csv\n",
    "from heap import Heap\n",
    "\n",
    "\n",
    "def make_date_key(row):\n",
    "    try:\n",
    "        year  = int(row[\"생년\"])\n",
    "        month = int(row[\"생월\"])\n",
    "        day   = int(row[\"생일\"])\n",
    "        if year < 1900 or year > 2100:\n",
    "            raise ValueError(f\"비정상 연도: {year}\")\n",
    "        return (year, month, day)\n",
    "    except (ValueError, KeyError):\n",
    "        return None\n",
    "\n",
    "\n",
    "people = []\n",
    "with open(\"birthday.csv\", encoding=\"utf-8\") as f:\n",
    "    for row in csv.DictReader(f):\n",
    "        key = make_date_key(row)\n",
    "        if key is None:\n",
    "            print(f\"[예외처리] {row['이름']}: 생년월일 데이터 오류 → 힙에서 제외\")\n",
    "        else:\n",
    "            people.append((key, row[\"이름\"]))\n",
    "\n",
    "heap = Heap()\n",
    "for key, name in people:\n",
    "    heap.insert((key, name))\n",
    "\n",
    "print(\"\\n[생년월일 순서 TOP 10 (생일 느린 순)]\")\n",
    "print(f\"{'순위':<5} {'이름':<8} 생년월일\")\n",
    "print(\"-\" * 28)\n",
    "rank = 1\n",
    "while not heap.isEmpty() and rank <= 10:\n",
    "    key, name = heap.deleteMax()\n",
    "    year, month, day = key\n",
    "    print(f\"{rank:<5} {name:<8} {year}년 {month:>2}월 {day:>2}일\")\n",
    "    rank += 1"
   ],
   "outputs": [
    {
     "output_type": "stream",
     "name": "stdout",
     "text": "[예외처리] 유지민: 생년월일 데이터 오류 → 힙에서 제외\n\n[생년월일 순서 TOP 10 (생일 느린 순)]\n순위   이름     생년월일\n----------------------------\n1     이윤서    2006년 12월 27일\n2     정희원    2006년 12월 21일\n3     김효린    2006년 12월 16일\n4     이예은    2006년 12월  9일\n5     엥흐툽신 엥흐톨 1985년 12월  5일\n6     정인선    2005년 11월 24일\n7     김주영    2006년 11월 20일\n8     진가연    2005년 11월 12일\n9     전은빈    2006년 11월  7일\n10    황다원    2004년 10월 15일\n"
    }
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "cell-problem4",
   "metadata": {},
   "source": [
    "import csv\n",
    "from circularDoublyLinkedList import CircularDoublyLinkedList\n",
    "\n",
    "\n",
    "# 우리 조 명단\n",
    "MY_TEAM = {\"이채윤\", \"구수진\", \"권지영\", \"김수민\", \"김주영\",\n",
    "           \"김태연\", \"김효린\", \"서지윤\", \"유지민\", \"이승주\"}\n",
    "\n",
    "\n",
    "def format_birthday(row):\n",
    "    try:\n",
    "        year  = int(row[\"생년\"])\n",
    "        month = int(row[\"생월\"])\n",
    "        day   = int(row[\"생일\"])\n",
    "        if year < 1900 or year > 2100:\n",
    "            raise ValueError(f\"비정상 연도: {year}\")\n",
    "        return f\"{year}년 {month}월 {day}일\"\n",
    "    except (ValueError, KeyError):\n",
    "        return \"생년월일 정보 없음\"\n",
    "\n",
    "\n",
    "cdll = CircularDoublyLinkedList()\n",
    "with open(\"birthday.csv\", encoding=\"utf-8\") as f:\n",
    "    for row in csv.DictReader(f):\n",
    "        if row[\"이름\"] in MY_TEAM:   # 우리 조만 추가\n",
    "            cdll.append(dict(row))\n",
    "\n",
    "print(\"[우리 조 생년월일 목록]\")\n",
    "print(f\"{'이름':<8} 생년월일\")\n",
    "print(\"-\" * 25)\n",
    "for person in cdll:\n",
    "    name     = person[\"이름\"]\n",
    "    birthday = format_birthday(person)\n",
    "    print(f\"{name:<8} {birthday}\")"
   ],
   "outputs": [
    {
     "output_type": "stream",
     "name": "stdout",
     "text": "[우리 조 생년월일 목록]\n이름     생년월일\n-------------------------\n이채윤    2005년 8월 21일\n구수진    2005년 4월 8일\n권지영    2003년 2월 5일\n김수민    2006년 7월 9일\n김주영    2006년 11월 20일\n김태연    2006년 3월 22일\n김효린    2006년 12월 16일\n서지윤    2005년 9월 22일\n유지민    생년월일 정보 없음\n이승주    2006년 3월 26일\n"
    }
   ]
  }
